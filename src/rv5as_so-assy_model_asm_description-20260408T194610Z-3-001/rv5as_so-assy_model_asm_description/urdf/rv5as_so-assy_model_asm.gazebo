  <material>${body_color}</material>
  <mu1>0.2</mu1>
  <mu2>0.2</mu2>
  <self_collide>true</self_collide>
</gazebo>

<gazebo reference="RV5AS_J2_NO1ARM_MODEL_1">
  <material>${body_color}</material>
